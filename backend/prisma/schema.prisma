generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  DEVELOPER
  RECRUITER
  ADMIN
}

enum ProjectStatus {
  IDEA
  BUILDING
  LAUNCHED
}

enum PostType {
  UPDATE
  PROJECT_LAUNCH
  BUILD_LOG
  CHALLENGE_SUBMISSION
  COLLAB_REQUEST
}

enum CollaborationStatus {
  OPEN
  ACCEPTED
  REJECTED
}

enum NotificationType {
  LIKE
  COMMENT
  FOLLOW
  CHALLENGE
  COLLAB
  SYSTEM
}

model User {
  id                    String                 @id @default(cuid())
  email                 String                 @unique
  passwordHash          String
  name                  String
  username              String                 @unique
  image                 String?
  role                  UserRole               @default(DEVELOPER)
  githubUsername        String?
  portfolioUrl          String?
  openToCollaborate     Boolean                @default(false)
  openToHire            Boolean                @default(false)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  profile               Profile?
  posts                 Post[]
  ownedProjects         Project[]              @relation("ProjectOwner")
  projectContributions  Project[]              @relation("ProjectContributors")
  comments              Comment[]
  likes                 Like[]
  bookmarks             Bookmark[]
  followers             Follow[]               @relation("FollowTarget")
  following             Follow[]               @relation("FollowSource")
  challengeSubmissions  ChallengeSubmission[]
  recruiterProfile      RecruiterProfile?
  sentCollabRequests    CollaborationRequest[] @relation("CollabRequester")
  receivedCollabRequest CollaborationRequest[] @relation("CollabRecipient")
  mentorChats           AIMentorChat[]
  notifications         Notification[]
  pinnedProjects        PinnedProject[]
  shortlistedBy         Shortlist[]
}

model Profile {
  id                    String   @id @default(cuid())
  userId                String   @unique
  bio                   String?
  location              String?
  skills                String[]
  badges                String[]
  projectsBuiltCount    Int      @default(0)
  contributionCount     Int      @default(0)
  streakDays            Int      @default(0)
  featuredHeadline      String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id                    String                 @id @default(cuid())
  title                 String
  slug                  String                 @unique
  shortDescription      String
  fullDescription       String
  media                 String[]
  githubUrl             String?
  liveDemoUrl           String?
  tags                  String[]
  status                ProjectStatus          @default(IDEA)
  category              String
  lookingForFeedback    Boolean                @default(false)
  lookingForCollaborator Boolean               @default(false)
  rolesNeeded           String[]
  ownerId               String
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  owner                 User                   @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  contributors          User[]                 @relation("ProjectContributors")
  posts                 Post[]
  updates               ProjectUpdate[]
  challengeSubmissions  ChallengeSubmission[]
  collaborationRequests CollaborationRequest[]
  aiReviews             AIReview[]
  score                 ProjectScore?
  pinnedBy              PinnedProject[]
}

model ProjectUpdate {
  id          String   @id @default(cuid())
  projectId   String
  dayLabel    String
  title       String
  description String
  media       String[]
  createdAt   DateTime @default(now())

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Post {
  id                    String    @id @default(cuid())
  authorId              String
  projectId             String?
  type                  PostType  @default(UPDATE)
  text                  String
  projectTitle          String?
  githubUrl             String?
  liveDemoUrl           String?
  media                 String[]
  techStack             String[]
  projectStage          ProjectStatus?
  lookingForFeedback    Boolean   @default(false)
  lookingForCollaborators Boolean @default(false)
  repostOfId            String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  author                User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  project               Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  comments              Comment[]
  likes                 Like[]
  bookmarks             Bookmark[]
  repostOf              Post?     @relation("RepostChain", fields: [repostOfId], references: [id])
  reposts               Post[]    @relation("RepostChain")
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  text      String
  createdAt DateTime @default(now())

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model Like {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model Bookmark {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower    User     @relation("FollowSource", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("FollowTarget", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model Tag {
  id        String   @id @default(cuid())
  label     String   @unique
  usage     Int      @default(0)
  createdAt DateTime @default(now())
}

model Challenge {
  id          String                @id @default(cuid())
  title       String
  description String
  category    String
  deadline    DateTime
  badge       String
  reward      String
  isActive    Boolean               @default(true)
  createdAt   DateTime              @default(now())

  submissions ChallengeSubmission[]
}

model ChallengeSubmission {
  id          String    @id @default(cuid())
  challengeId String
  projectId   String
  userId      String
  note        String?
  isWinner    Boolean   @default(false)
  createdAt   DateTime  @default(now())

  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, projectId])
}

model RecruiterProfile {
  id            String      @id @default(cuid())
  userId        String      @unique
  company       String
  roleTitle     String
  hiringFor     String[]
  savedTalent   Shortlist[]
  createdAt     DateTime    @default(now())

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Shortlist {
  id                String           @id @default(cuid())
  recruiterProfileId String
  userId            String
  note              String?
  createdAt         DateTime         @default(now())

  recruiterProfile  RecruiterProfile @relation(fields: [recruiterProfileId], references: [id], onDelete: Cascade)
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([recruiterProfileId, userId])
}

model CollaborationRequest {
  id          String              @id @default(cuid())
  projectId   String
  requesterId String
  recipientId String
  roleNeeded  String
  message     String
  status      CollaborationStatus @default(OPEN)
  createdAt   DateTime            @default(now())

  project     Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requester   User                @relation("CollabRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  recipient   User                @relation("CollabRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
}

model ProjectScore {
  id               String   @id @default(cuid())
  projectId        String   @unique
  qualityScore     Int
  innovationScore  Int
  complexityScore  Int
  overallScore     Int
  generatedBy      String   @default("rules-engine")
  createdAt        DateTime @default(now())

  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model AIReview {
  id                 String   @id @default(cuid())
  projectId          String
  prompt             String
  codeQuality        String
  suggestions        String[]
  improvements       String[]
  bugDetections      String[]
  performanceTips    String[]
  createdAt          DateTime @default(now())

  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model AIMentorChat {
  id          String   @id @default(cuid())
  userId      String
  prompt      String
  response    String
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id          String           @id @default(cuid())
  userId      String
  type        NotificationType
  title       String
  message     String
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PinnedProject {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  order     Int      @default(0)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}
